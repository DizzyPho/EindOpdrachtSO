<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoListGUI.Pages.TaskListPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
       

        <HorizontalStackLayout Grid.Row="0" 
                               Grid.ColumnSpan="2">
            <Button Text="Show All" Margin="8" BackgroundColor="PaleVioletRed"></Button>
            <Button Text="Show Unfinished" Margin="8" BackgroundColor="PaleVioletRed"></Button>
            <Button Text="Show All (sort by most recent)" Margin="8" BackgroundColor="PaleVioletRed"></Button>
        </HorizontalStackLayout>

        <CollectionView Grid.Row="1" 
                        Grid.ColumnSpan="2"
                        ItemsSource="{Binding Tasks}"
                        Margin="8">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8"></LinearItemsLayout>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border>
                        <HorizontalStackLayout>
                            <CheckBox Margin="8" 
                                  IsChecked="{Binding IsCompleted}"
                                  VerticalOptions="Center"
                                  HorizontalOptions="Center"></CheckBox>
                            <VerticalStackLayout>
                                <Label FontAttributes="Bold" 
                                   Text="{Binding Title}"
                                   Margin="8, 8, 8, 2"></Label>
                                <Label Text="{Binding Description}"
                                   Margin="8, 2, 8, 8"></Label>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2" 
                Grid.Column="0" 
                Margin="8"
                Text="Users"
                BackgroundColor="DarkViolet"></Button>
        <Button Grid.Row="2" 
                Grid.Column="1" 
                Margin="8"
                Text="New Task"
                BackgroundColor="DarkViolet"></Button>
        
    </Grid>
</ContentPage>
