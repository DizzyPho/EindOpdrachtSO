<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoListGUI.Pages.TaskDetailPage"
             Title="TaskDetailPage">
    <VerticalStackLayout>
        <Label Margin="8" Text="TITLE" TextColor="PaleVioletRed" FontSize="Subtitle"></Label>
        <Entry Margin="8"></Entry>
        <Label Margin="8" Text="DESCRIPTION" TextColor="PaleVioletRed" FontSize="Subtitle"></Label>
        <Entry Margin="8"></Entry>
        <Label Margin="8" Text="USER" TextColor="PaleVioletRed" FontSize="Subtitle"></Label>
        <Picker Margin="8"></Picker>
        <Label Margin="8" Text="COMPLETED?" TextColor="PaleVioletRed" FontSize="Subtitle"></Label>
        <CheckBox></CheckBox>
    </VerticalStackLayout>
</ContentPage>